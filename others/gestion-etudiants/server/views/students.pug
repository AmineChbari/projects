doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Gestion Étudiants
    link(rel="stylesheet" href="/style/main.css")
    script(src="/scripts/students.bundle.js" defer)
  body
    header
      nav
        ul
          li: a(href="/") Accueil
          li: a(href="/groups") Gérer les Groupes
    h1 Gestion des Étudiants
    div#message
    section.container
      div.form-section
        h2 Ajouter un Étudiant
        form#student-form
          div.form-group
            label(for="studentNumber") Numéro Étudiant
            input#studentNumber(type="text" placeholder="Ex: S013" required)
          div.form-group
            label(for="name") Nom (en majuscules)
            input#name(type="text" placeholder="Ex: DUPONT" required)
          div.form-group
            label(for="surnames") Prénoms (séparés par des virgules)
            input#surnames(type="text" placeholder="Ex: Jean, Michel" required)
          div.form-buttons
            button#add-student-btn(type="button") Ajouter
            button#clear-form-btn(type="button") Effacer
      
      div.students-section
        h2 Liste des Étudiants
        ul#students-list
          each student in students
            li.student-item
              div.student-info
                strong #{student.studentNumber}
                |  - #{student.name} (#{student.surnames})
              span.student-status
                if student.groupNumber
                  | groupe #{student.groupNumber}
                else
                  | Pas de groupe !
    footer
      p © 2025 Gestion Étudiants et Groupes.
      p Développé par [CHBARI Amine]